{
  "name": "@omnidotdev/template-react-native",
  "main": "expo-router/entry",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.6",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "check": "biome check --diagnostic-level=error src",
    "format": "biome format --write src",
